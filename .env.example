# ============================================================================
# Kernes - Variables de Entorno
# ============================================================================
# Copia este archivo a .env.local y rellena tus valores
# NUNCA commitees el archivo .env.local
# ============================================================================

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
# URL del API Gateway (desarrollo local o producción)
VITE_API_GATEWAY_URL=http://localhost:8787
# VITE_API_GATEWAY_URL=https://api.kernes.org

# ---------------------------------------------------------------------------
# Ceramic / DIDs (Identidad Descentralizada)
# ---------------------------------------------------------------------------
# URL de la red Ceramic para DIDs
# Red de desarrollo (Clay Testnet)
VITE_CERAMIC_API_URL=https://ceramic-clay.3boxlabs.com
# Red de producción (Mainnet)
# VITE_CERAMIC_API_URL=https://ceramic.kernes.org

# URL del proveedor DID local (desarrollo)
VITE_DID_PROVIDER_URL=http://localhost:8081

# ---------------------------------------------------------------------------
# IPFS (Almacenamiento Descentralizado)
# ---------------------------------------------------------------------------
# Gateway IPFS para recuperar contenido
VITE_IPFS_GATEWAY=https://gateway.ipfs.io
# Gateway IPFS propio (producción)
# VITE_IPFS_GATEWAY=https://ipfs.kernes.org

# ---------------------------------------------------------------------------
# NLP Local (Ollama)
# ---------------------------------------------------------------------------
# URL del servidor Ollama para procesamiento NLP local
# Instala Ollama en tu máquina o usa el túnel de Termux
VITE_OLLAMA_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Monitoreo y Errores (Opcional)
# ---------------------------------------------------------------------------
# DSN de Sentry para reporte de errores (solo producción)
# VITE_SENTRY_DSN=https://xxxx@yyyy.ingest.sentry.io/zzzz

# ---------------------------------------------------------------------------
# Modo Desarrollo
# ---------------------------------------------------------------------------
# Activa logs detallados y herramientas de debug
VITE_DEV_MODE=true

# Desactiva la ofuscación en desarrollo para facilitar debugging
VITE_CHAFF_DISABLED=false

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
# Activa/desactiva módulos en desarrollo
VITE_ENABLE_SENTINEL=true
VITE_ENABLE_CHAFF=true
VITE_ENABLE_LEXAI=true
VITE_ENABLE_SOVEREIGN_VAULT=false
VITE_ENABLE_ZK_PROOFS=false
