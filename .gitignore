# ============================================================================
# KERNES - .gitignore
# ============================================================================

# ---------------------------------------------------------------------------
# Dependencias
# ---------------------------------------------------------------------------
node_modules/
.pnpm-store/
.yarn/
package-lock.json
yarn.lock

# ---------------------------------------------------------------------------
# Builds y outputs
# ---------------------------------------------------------------------------
dist/
build/
out/
.next/
*.tsbuildinfo
.turbo/

# ---------------------------------------------------------------------------
# Variables de entorno (NUNCA subir)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
.dev.vars
*.pem
*.key

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/
.npm-debug.log*
.pnpm-debug.log*

# ---------------------------------------------------------------------------
# Sistema operativo
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# IDEs y editores
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-*

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
coverage/
.nyc_output/

# ---------------------------------------------------------------------------
# Extensiones de navegador
# ---------------------------------------------------------------------------
*.zip
*.crx
*.xpi
web-ext-artifacts/

# ---------------------------------------------------------------------------
# Smart contracts
# ---------------------------------------------------------------------------
cache/
out/
broadcast/

# ---------------------------------------------------------------------------
# ZK Circuits
# ---------------------------------------------------------------------------
*.ptau
*.zkey
*.r1cs
*.wasm
witness.wtns
proof.json
public.json

# ---------------------------------------------------------------------------
# Mobile / Capacitor
# ---------------------------------------------------------------------------
android/app/build/
ios/App/build/
.env.local
.dev.vars
